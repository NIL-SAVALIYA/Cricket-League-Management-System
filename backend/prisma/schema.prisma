generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}

model User {
  id              String   @id @default(uuid())
  firstName       String
  lastName        String
  email           String   @unique
  password        String
  phone           String?
  profileImageUrl String?
  isActive        Boolean  @default(true)
  roleId          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  teams           Team[]
  role            Role     @relation(fields: [roleId], references: [id])
}

model Team {
  id          String  @id @default(uuid())
  name        String  @unique
  shortName   String  @unique
  logoUrl     String?
  city        String
  description String?
  managerId   String?

  tournaments TournamentTeam[]

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  matchesAsTeamA Match[]   @relation("TeamA")
  matchesAsTeamB Match[]   @relation("TeamB")
  tossWonMatches Match[]   @relation("TossWinner")
  wonMatches     Match[]   @relation("WinnerTeam")
  battingInnings Innings[] @relation("BattingTeam")

  bowlingInnings Innings[] @relation("BowlingTeam")

  players Player[]

  playingXI PlayingXI[]
  manager   User?       @relation(fields: [managerId], references: [id])
}

model Innings {
  id String @id @default(uuid())

  matchId String

  battingTeamId String

  bowlingTeamId String

  inningsNumber Int

  totalRuns Int @default(0)

  wickets Int @default(0)

  overs Decimal @default(0)

  totalBalls Int @default(0)

  legalBalls Int @default(0)

  currentRunRate Float @default(0)

  balls Ball[]

  partnerships Partnership[]

  status InningsStatus @default(LIVE)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  match Match @relation(fields: [matchId], references: [id])

  battingTeam Team @relation("BattingTeam", fields: [battingTeamId], references: [id])

  bowlingTeam Team @relation("BowlingTeam", fields: [bowlingTeamId], references: [id])

  battingScorecards BattingScorecard[]

  bowlingScorecards BowlingScorecard[]

  fallOfWickets FallOfWicket[]

  @@index([matchId])
  @@index([status])
}

model Ball {
  id String @id @default(uuid())

  inningsId String

  deliveryNumber Int

  over Int

  ball Int

  batsmanId String

  bowlerId String

  nonStrikerId String

  batRuns Int @default(0)

  extraRuns Int @default(0)

  totalRuns Int @default(0)

  extraType ExtraType @default(NONE)

  isLegalDelivery Boolean @default(true)

  isBoundaryFour Boolean @default(false)

  isBoundarySix Boolean @default(false)

  isWicket Boolean @default(false)

  wicketType WicketType?

  dismissedPlayerId String?

  fielderId String?

  commentary String?

  createdAt DateTime @default(now())

  innings Innings @relation(fields: [inningsId], references: [id])

  batsman Player @relation("Batsman", fields: [batsmanId], references: [id])

  nonStriker Player @relation("NonStriker", fields: [nonStrikerId], references: [id])

  bowler Player @relation("Bowler", fields: [bowlerId], references: [id])

  dismissedPlayer Player? @relation("DismissedPlayer", fields: [dismissedPlayerId], references: [id])

  fielder Player? @relation("Fielder", fields: [fielderId], references: [id])

  @@index([inningsId])
  @@index([deliveryNumber])
  @@index([inningsId, deliveryNumber])
}

model Player {
  id            String        @id @default(uuid())
  firstName     String
  lastName      String
  dateOfBirth   DateTime?
  jerseyNumber  Int?
  playerType    PlayerType
  battingStyle  BattingStyle?
  bowlingStyle  BowlingStyle?
  isCaptain     Boolean       @default(false)
  isViceCaptain Boolean       @default(false)
  teamId        String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  team          Team          @relation(fields: [teamId], references: [id])

  battingBalls Ball[] @relation("Batsman")

  nonStrikerBalls Ball[] @relation("NonStriker")

  bowlingBalls Ball[] @relation("Bowler")

  dismissals Ball[] @relation("DismissedPlayer")

  fieldingBalls Ball[] @relation("Fielder")

  playingXI PlayingXI[]

  fallOfWickets FallOfWicket[]

  partnershipsAsStriker Partnership[] @relation("PartnershipStriker")

  partnershipsAsNonStriker Partnership[] @relation("PartnershipNonStriker")

  // Batting Scorecard
  battingScorecards BattingScorecard[] @relation("BattingPlayer")

  dismissalBowlingScorecards BattingScorecard[] @relation("DismissalBowler")

  dismissalFieldingScorecards BattingScorecard[] @relation("DismissalFielder")

  // Bowling Scorecard
  bowlingScorecards BowlingScorecard[]
}

model Match {
  id String @id @default(uuid())

  tournamentId String

  teamAId String

  teamBId String

  venue String

  matchDate DateTime

  tossWinnerId String?

  tossDecision TossDecision?

  status MatchStatus @default(UPCOMING)

  tournament Tournament @relation(fields: [tournamentId], references: [id])

  teamA Team @relation("TeamA", fields: [teamAId], references: [id])

  teamB Team @relation("TeamB", fields: [teamBId], references: [id])

  tossWinner Team? @relation("TossWinner", fields: [tossWinnerId], references: [id])

  winnerTeamId String?

  winnerTeam Team? @relation("WinnerTeam", fields: [winnerTeamId], references: [id])

  result String?

  winningMargin String?

  completedAt DateTime?

  innings Innings[]

  playingXI PlayingXI[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([tournamentId])
  @@index([status])
  @@index([winnerTeamId])
}

model Tournament {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  format      TournamentFormat
  startDate   DateTime
  endDate     DateTime
  status      TournamentStatus @default(UPCOMING)

  registeredTeams TournamentTeam[]

  matches Match[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TournamentTeam {
  id String @id @default(uuid())

  tournamentId String
  teamId       String

  tournament Tournament @relation(fields: [tournamentId], references: [id])

  team Team @relation(fields: [teamId], references: [id])

  createdAt DateTime @default(now())

  @@unique([tournamentId, teamId])
}

model BattingScorecard {
  id String @id @default(uuid())

  inningsId String

  playerId String

  battingPosition Int

  runs Int @default(0)

  balls Int @default(0)

  fours Int @default(0)

  sixes Int @default(0)

  strikeRate Float @default(0)

  isOut Boolean @default(false)

  dismissalType WicketType?

  bowlerId String?

  fielderId String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  innings Innings @relation(fields: [inningsId], references: [id])

  player Player @relation("BattingPlayer", fields: [playerId], references: [id])

  bowler Player? @relation("DismissalBowler", fields: [bowlerId], references: [id])

  fielder Player? @relation("DismissalFielder", fields: [fielderId], references: [id])

  @@index([inningsId])
  @@index([playerId])
}

model BowlingScorecard {
  id String @id @default(uuid())

  inningsId String

  bowlerId String

  overs Int @default(0)

  balls Int @default(0)

  maidens Int @default(0)

  runs Int @default(0)

  wickets Int @default(0)

  noBalls Int @default(0)

  wides Int @default(0)

  economy Float @default(0)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  innings Innings @relation(fields: [inningsId], references: [id])

  bowler Player @relation(fields: [bowlerId], references: [id])

  @@index([inningsId])
  @@index([bowlerId])
}

model PlayingXI {
  id String @id @default(uuid())

  matchId String

  playerId String

  teamId String

  battingOrder Int

  isCaptain Boolean @default(false)

  isWicketKeeper Boolean @default(false)

  isSubstitute Boolean @default(false)

  isImpactPlayer Boolean @default(false)

  createdAt DateTime @default(now())

  match Match @relation(fields: [matchId], references: [id])

  player Player @relation(fields: [playerId], references: [id])

  team Team @relation(fields: [teamId], references: [id])

  @@unique([matchId, playerId])
  @@index([matchId])
}

model FallOfWicket {
  id String @id @default(uuid())

  inningsId String

  playerId String

  wicketNumber Int

  score Int

  batsmanRuns Int

  over String

  ball Int

  wicketType WicketType

  createdAt DateTime @default(now())

  innings Innings @relation(fields: [inningsId], references: [id])

  player Player @relation(fields: [playerId], references: [id])

  @@index([inningsId])
}

model Partnership {
  id String @id @default(uuid())

  inningsId String

  strikerId String

  nonStrikerId String

  runs Int @default(0)

  balls Int @default(0)

  fours Int @default(0)

  sixes Int @default(0)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  innings Innings @relation(fields: [inningsId], references: [id])

  striker Player @relation("PartnershipStriker", fields: [strikerId], references: [id])

  nonStriker Player @relation("PartnershipNonStriker", fields: [nonStrikerId], references: [id])

  @@index([inningsId])
}

enum PlayerType {
  BATSMAN
  BOWLER
  ALL_ROUNDER
  WICKET_KEEPER
}

enum BattingStyle {
  RIGHT_HAND
  LEFT_HAND
}

enum BowlingStyle {
  RIGHT_ARM_FAST
  LEFT_ARM_FAST
  RIGHT_ARM_MEDIUM
  LEFT_ARM_MEDIUM
  RIGHT_ARM_SPIN
  LEFT_ARM_SPIN
}

enum MatchStatus {
  UPCOMING
  LIVE
  COMPLETED
  CANCELLED
}

enum TossDecision {
  BAT
  BOWL
}

enum TournamentFormat {
  LEAGUE
  KNOCKOUT
  ROUND_ROBIN
  HYBRID
}

enum TournamentStatus {
  UPCOMING
  LIVE
  COMPLETED
  CANCELLED
}

enum InningsStatus {
  LIVE
  COMPLETED
}

enum ExtraType {
  NONE
  WIDE
  NO_BALL
  BYE
  LEG_BYE
}

enum WicketType {
  BOWLED
  CAUGHT
  LBW
  RUN_OUT
  STUMPED
  HIT_WICKET
}

enum MatchResultType {
  RUNS
  WICKETS
  TIE
  NO_RESULT
}
